# VoiceMind Backend — copy to .env and fill in values
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Gemini API (REST: /chat, /quick_emotion, ADK agents)
# Get a key: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Firebase / Firestore (admin dashboard, event logging, token verification)
# Set this to your own Firebase project ID after running `flutterfire configure`.
# Leave blank if you don't want Firestore-backed event logging.
# -----------------------------------------------------------------------------
FIREBASE_PROJECT=

# -----------------------------------------------------------------------------
# Admin dashboard (optional)
# If set, the admin dashboard at /admin will require a Firebase ID token from
# this email address. Leave blank for open-access local dev.
# -----------------------------------------------------------------------------
ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8000
HOST=0.0.0.0
DEBUG=True
